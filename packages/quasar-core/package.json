{
  "name": "@kalisio/quasar-core",
  "description": "Core components for kalisio ekosystem",
  "version": "0.0.0",
  "packageManager": "pnpm@10.1.0",
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.js",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "standard": {
    "ignore": [
      "dist/**"
    ]
  },
  "scripts": {
    "build": "vite build",
    "lint": "standard --fix",
    "test": "vitest run --coverage"
  },
  "keywords": [
    "kalisio"
  ],
  "author": {
    "name": "Kalisio",
    "email": "contact@kalisio.com",
    "url": "https://github.com/kalisio"
  },
  "contributors": [],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kalisio/quasar-ekosystem.git",
    "directory": "packages/quasar-core"
  },
  "bugs": {
    "url": "https://github.com/kalisio/quasar-ekosystem/issues"
  },
  "homepage": "https://github.com/kalisio/quasar-ekosystem/tree/main/packages/quasar-core",
  "peerDependencies": {
    "@kalisio/common-core": "catalog:",
    "@kalisio/common-graphics": "catalog:",
    "@logtape/logtape": "catalog:",
    "@thumbmarkjs/thumbmarkjs": "catalog:",
    "chroma-js": "catalog:",
    "lodash-es": "catalog:",
    "mathjs": "catalog:",
    "moment": "catalog:",
    "quasar": "catalog:",
    "sanitize-html": "catalog:",
    "sift": "catalog:",
    "vue": "catalog:",
    "vue-router": "catalog:"
  },
  "devDependencies": {
    "@quasar/quasar-app-extension-testing-unit-vitest": "catalog:",
    "@quasar/vite-plugin": "catalog:",
    "@vue/test-utils": "catalog:",
    "happy-dom": "catalog:",
    "sass": "^1.99.0",
    "vue-router-mock": "catalog:"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs"
      }
    }
  }
}