{
  "name": "quasar-ekosystem",
  "description": "A collection of advanced components for extending the Quasar Framework",
  "packageManager": "pnpm@10.1.0",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "build:quasar-core": "pnpm --filter @kalisio/quasar-core build",
    "build:quasar-form": "pnpm --filter @kalisio/quasar-form build",
    "build:quasar-moment": "pnpm --filter @kalisio/quasar-moment build",
    "changeset": "changeset",
    "changeset:publish": "pnpm build && changeset publish",
    "changeset:status": "changeset status",
    "changeset:version": "changeset version",
    "clear": "pnpm -r exec rimraf node_modules dist coverage",
    "docs:build": "pnpm --filter docs run build",
    "docs:dev": "pnpm --filter docs run dev",
    "inspect": "pnpm knip",
    "lint": "pnpm -r lint",
    "lint:quasar-core": "pnpm --filter @kalisio/quasar-core lint",
    "lint:quasar-form": "pnpm --filter @kalisio/quasar-form lint",
    "lint:quasar-moment": "pnpm --filter @kalisio/quasar-moment lint",
    "posttest": "pnpm lcov-result-merger --prepend-source-files 'packages/*/coverage/lcov.info' coverage/lcov.info",
    "prepare": "husky",
    "pretest": "mkdir -p coverage",
    "test": "pnpm -r test",
    "test:quasar-core": "pnpm --filter @kalisio/quasar-core test",
    "test:quasar-form": "pnpm --filter @kalisio/quasar-form test",
    "test:quasar-moment": "pnpm --filter @kalisio/quasar-moment test --coverage"
  },
  "keywords": [
    "form",
    "quasar",
    "ekosystem",
    "kalisio"
  ],
  "author": {
    "name": "KALISIO <contact@kalisio.com>",
    "url": "https://github.com/kalisio"
  },
  "contributors": [],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git://github.com/kalisio/quasar-ekosystem.git"
  },
  "bugs": {
    "url": "https://github.com/kalisio/quasar-ekosystem/issues"
  },
  "homepage": "git://github.com/kalisio/quasar-ekosystem#readme",
  "devDependencies": {
    "@changesets/cli": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "cross-env": "catalog:",
    "husky": "catalog:",
    "lcov-result-merger": "catalog:",
    "lint-staged": "catalog:",
    "rimraf": "catalog:",
    "standard": "catalog:",
    "vite": "catalog:",
    "vite-bundle-visualizer": "catalog:",
    "vitest": "catalog:",
    "knip": "catalog:"
  },
  "metaCatalog": {
    "version": "0.9.0",
